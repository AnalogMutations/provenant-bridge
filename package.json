{
  "name": "@provenant/bridge",
  "version": "0.1.0",
  "description": "Local bridge for Provenant. Reads your Claude Code transcripts and runs analysis against your existing Pro/Max subscription via the claude CLI. Listens on 127.0.0.1; provenanthq.com talks to it from the browser.",
  "license": "Proprietary",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://provenanthq.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnalogMutations/provenant-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/AnalogMutations/provenant-bridge/issues"
  },
  "keywords": [
    "provenant",
    "claude",
    "claude-code",
    "hiring",
    "fingerprint"
  ],
  "bin": {
    "provenant": "dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js serve",
    "prepare": "tsc",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.4"
  }
}
